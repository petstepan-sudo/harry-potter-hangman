# Zkopírujte jako .env (soubor .env není v gitu).
# Hodnoty z Supabase: Project Settings → API
# Proměnné MUSÍ začínat na VITE_ (jinak je Vite do aplikace nevpíchne).
# Lokálně hru spusťte: npm install && npm run dev — neotvírejte jen index.html z Průzkumníka.

VITE_SUPABASE_URL=...
VITE_SUPABASE_ANON_KEY=...

# Volitelně pro build nasazený do podadresáře na GitHub Pages:
# VITE_BASE_PATH=/nazev-repo/
